# Copy to .env and fill in values for local and production runs.

# --- MySQL ---
# DB_HOST / DB_PORT trỏ tới instance MySQL của bạn (mặc định localhost:3306).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=recruitment_db

# --- App secrets ---
# Production: set JWT_SECRET to a random string of at least 32 characters (gateway refuses weak defaults).
JWT_SECRET=use_a_long_random_string_in_production

# Graceful shutdown timeout (ms) when receiving SIGTERM/SIGINT — gateway only
# SHUTDOWN_TIMEOUT_MS=10000

# --- AI ---
# AI_PROVIDER=gemini (mặc định): cần AI_API_KEY (Google AI Studio / Gemini).
# AI_PROVIDER=openai: cần OPENAI_API_KEY; không dùng AI_API_KEY cho chat/generate.
# AI_PROVIDER=poe: Poe OpenAI-compatible API — POE_API_KEY (https://poe.com/api/keys), POE_BOT=tên bot công khai (vd JobMentorAI).
#   Embedding trong app vẫn cần AI_API_KEY (Gemini) và/hoặc OPENAI_API_KEY (OpenAI gốc); Poe không dùng cho embeddings.
# Đổi provider sau khi đã lưu embedding trong DB: vector cũ (Gemini) không so sánh được với embedding OpenAI — nên migrate hoặc tính lại embedding.
AI_PROVIDER=gemini
AI_API_KEY=
AI_MODEL=gemini-2.5-flash
AI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash-lite,gemini-flash-latest
# OpenAI (khi AI_PROVIDER=openai); tùy chọn OPENAI_BASE_URL (proxy / Azure)
OPENAI_API_KEY=
# OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_FALLBACKS=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Poe (khi AI_PROVIDER=poe)
# POE_API_KEY=
# POE_API_BASE_URL=https://api.poe.com/v1
# POE_BOT=JobMentorAI
# POE_BOT_FALLBACKS=

# --- Chatbot Flask (tùy chọn): sinh câu trả lời tư vấn nghề qua HTTP ---
# Để trống = gateway Node gọi Gemini/OpenAI trực tiếp (mặc định).
# Local: CHATBOT_SERVICE_URL=http://127.0.0.1:5100 (xem chatbot-service/README.md)
# CHATBOT_SERVICE_URL=
# CHATBOT_API_SECRET=  # nên đặt chuỗi ngẫu nhiên; Flask và backend dùng cùng giá trị (header X-Chatbot-Secret)
# CHATBOT_SERVICE_TIMEOUT_MS=120000

# --- API server (monolith: auth, jobs, candidates, AI trong một process) ---
PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Production: thêm https://yourdomain.com (và mọi origin hợp lệ khác)

# OAuth (tùy chọn — đăng nhập xã hội)
# AUTH_FRONTEND_URL=http://localhost:3000
# OAUTH_GATEWAY_PUBLIC_URL=http://localhost:5000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Client (Vite; prefix VITE_) ---
VITE_API_URL=/api
# VITE_API_ORIGIN=http://localhost:5000
# Poe nhúng trong widget chat (mặc định trong code đã có link mời; ghi đè hoặc tắt):
# VITE_POE_CHAT_URL=https://poe.com/invite/...
# Đặt rỗng trong .env để tắt Poe: VITE_POE_CHAT_URL=
# Hoặc: VITE_POE_CHAT_ENABLED=false
