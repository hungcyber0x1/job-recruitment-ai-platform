# Gateway-only vars when running `server/` alone. Full stack: copy root `.env.example` → `.env`.
# Production: NODE_ENV=production requires JWT_SECRET ≥32 chars and not the dev default (see validateEnv).

PORT=5000
DB_HOST=localhost
# MySQL mặc định 3306. Chỉ dùng 3308 khi Docker map cổng host → container.
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=recruitment_db
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d
# AI_PROVIDER=gemini | openai | poe
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash-lite,gemini-flash-latest
# JSON một lượt (phân tích CV, …). Mặc định 4096; tăng nếu model cắt giữa chừng.
# AI_CONTENT_MAX_TOKENS=4096
AI_API_KEY=
OPENAI_API_KEY=
# OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_FALLBACKS=gpt-4o
# POE_API_KEY=
# POE_API_BASE_URL=https://api.poe.com/v1
# POE_BOT=JobMentorAI
# POE_BOT_FALLBACKS=
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# SHUTDOWN_TIMEOUT_MS=10000
