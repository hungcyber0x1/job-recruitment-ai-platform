-- =============================================================================
-- PHASE 17: CLEANUP
-- =============================================================================

-- Drop legacy columns if any remain (check first)
-- ALTER TABLE users DROP COLUMN IF EXISTS is_active; -- UNCOMMENT ONLY IF READY TO BREAK OLD CODE

-- Re-enable foreign key checks
SET FOREIGN_KEY_CHECKS = 1;

-- =============================================================================
-- VERIFICATION
-- =============================================================================

SELECT 'Migration completed successfully!' AS status, NOW() AS completed_at;

-- Show final table list
SHOW TABLES;

-- Record counts
SELECT 'users' AS tbl, COUNT(*) AS cnt FROM users
UNION ALL SELECT 'company_profiles', COUNT(*) FROM company_profiles
UNION ALL SELECT 'candidate_profiles', COUNT(*) FROM candidate_profiles
UNION ALL SELECT 'jobs', COUNT(*) FROM jobs
UNION ALL SELECT 'applications', COUNT(*) FROM applications
UNION ALL SELECT 'blog_posts', COUNT(*) FROM blog_posts
UNION ALL SELECT 'categories', COUNT(*) FROM categories
UNION ALL SELECT 'skills', COUNT(*) FROM skills
UNION ALL SELECT 'locations', COUNT(*) FROM locations
UNION ALL SELECT 'chatbot_conversations', COUNT(*) FROM chatbot_conversations
UNION ALL SELECT 'chatbot_messages', COUNT(*) FROM chatbot_messages
UNION ALL SELECT 'user_preferences', COUNT(*) FROM user_preferences
UNION ALL SELECT 'system_settings', COUNT(*) FROM system_settings;

