-- =============================================================================
-- 5. VERIFICATION QUERIES
-- =============================================================================

-- Verify role migration
SELECT role, COUNT(*) as count FROM users GROUP BY role;

-- Verify table record counts
SELECT 'company_profiles' as tbl, COUNT(*) as cnt FROM company_profiles
UNION ALL SELECT 'candidate_profiles', COUNT(*) FROM candidate_profiles
UNION ALL SELECT 'users', COUNT(*) FROM users;

-- Verify foreign key integrity
SELECT 'Orphan jobs (no company)' as check_name, COUNT(*) as issues 
FROM jobs j 
LEFT JOIN company_profiles c ON j.company_id = c.id 
WHERE c.id IS NULL;

SELECT 'Orphan applications (no candidate)' as check_name, COUNT(*) as issues 
FROM applications a 
LEFT JOIN candidate_profiles c ON a.candidate_id = c.id 
WHERE c.id IS NULL;

-- =============================================================================
-- 6. ROLLBACK PLAN (if needed)
-- =============================================================================

/--
-- If you need to rollback:
-- 1. Keep backup of old database before migration
-- 2. Restore from backup:
--    SOURCE backup/recruitment_db_backup_pre_migration.sql;
-- 3. Discard new tables if they exist:
--    DROP TABLE IF EXISTS company_profiles;
--    DROP TABLE IF EXISTS candidate_profiles;
--    ... (list all new tables)
-- 
-- OR
-- 
-- If using incremental migration (keeping both schemas):
-- 1. Keep both old and new tables
-- 2. Create views for backward compatibility
-- 3. Update code gradually to use new tables
-- /

-- =============================================================================
-- POST-MIGRATION VALIDATION
-- =============================================================================

SELECT 'Migration complete!' as status, NOW() as completed_at;

-- Check that all required tables exist
SELECT 
  TABLE_NAME,
  TABLE_ROWS as estimated_rows
FROM information_schema.TABLES 
WHERE TABLE_SCHEMA = DATABASE()
ORDER BY TABLE_NAME;
