-- =============================================================================
-- CODEBASE UPDATE MIGRATION
-- Update all table names and column references in application code
-- =============================================================================

-- =============================================================================
-- IMPORTANT: Run this AFTER applying the new schema (045_new_schema_complete.sql)
-- =============================================================================

SET NAMES utf8mb4;

-- =============================================================================
-- 1. UPDATE USER ROLES
-- Old: 'employer' → New: 'recruiter'
-- =============================================================================

UPDATE users SET role = 'recruiter' WHERE role = 'employer';

-- =============================================================================
-- 2. RENAME TABLES (Alternative approach - use if renaming is preferred)
-- =============================================================================

-- Note: MySQL does not support direct RENAME TABLE across schemas easily
-- Use these as reference for code updates:

/--
-- Application code updates needed:
-- 
-- FROM:                    TO:
-- ---------------------------------------------
-- employers              → company_profiles
-- candidates             → candidate_profiles
-- chat_messages          → chatbot_messages
-- conversations          → chatbot_conversations
-- chatbot_analytics     → chatbot_analytics (keep)
-- support_tickets       → support_tickets (keep)
-- ticket_messages        → support_messages
-- content_pages         → content_pages (keep)
-- banners               → banners (keep)
-- 
-- Column renames:
-- ---------------------------------------------
-- employers.company_name    → company_profiles.name
-- employers.company_logo    → company_profiles.logo_url
-- employers.company_description → company_profiles.full_description
-- candidates.resume_url     → candidate_profiles.resume_url
-- candidates.bio           → candidate_profiles.bio
-- candidates.education     → candidate_profiles.education (JSON)
-- candidates.experience     → candidate_profiles.experience (JSON)
-- 
-- Foreign key changes:
-- ---------------------------------------------
-- jobs.employer_id         → jobs.company_id
-- applications.candidate_id → applications.candidate_id (via candidate_profiles)
-- blog_posts.employer_id    → blog_posts.company_id
-- 
-- Enum value changes:
-- ---------------------------------------------
-- users.role: 'employer'    → 'recruiter'
-- jobs.type: 'remote'       → 'remote' (keep)
-- 
-- Status standardization:
-- ---------------------------------------------
-- Remove is_active usage - use status column only
-- Standard statuses: active, pending, inactive, banned, locked
-- 
-- /

-- =============================================================================
-- 3. ADD INDEXES FOR PERFORMANCE (if not already added)
-- =============================================================================

-- These indexes are critical for query performance
CREATE INDEX IF NOT EXISTS idx_jobs_company ON jobs(company_id);
CREATE INDEX IF NOT EXISTS idx_jobs_category ON jobs(category_id);
CREATE INDEX IF NOT EXISTS idx_applications_job ON applications(job_id);
CREATE INDEX IF NOT EXISTS idx_applications_candidate ON applications(candidate_id);
CREATE INDEX IF NOT EXISTS idx_blog_company ON blog_posts(company_id);
CREATE INDEX IF NOT EXISTS idx_company_user ON company_profiles(user_id);
CREATE INDEX IF NOT EXISTS idx_candidate_user ON candidate_profiles(user_id);

-- =============================================================================
-- 4. DATA MIGRATION (Copy data from old tables to new if doing incremental migration)
-- =============================================================================

/-- 
