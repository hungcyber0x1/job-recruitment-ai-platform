# SPA gọi API qua cùng origin → Vite proxy /api tới gateway
VITE_API_URL=/api

# Dev: gateway mặc định 127.0.0.1:5000 (tránh IPv6 localhost trên Windows).
# Nếu gateway listen cổng khác (vd. PORT_FALLBACK): đặt đúng URL đó.
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:5000

# Socket.IO nên đi thẳng tới gateway, không đi qua /socket.io của Vite dev server.
# Nếu bật PORT_FALLBACK hoặc đổi PORT backend, đặt cùng origin với gateway.
# VITE_SOCKET_ORIGIN=http://127.0.0.1:5000
